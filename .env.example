# ── PKM Bot Gratuito — variáveis de ambiente ──────────────────────────────
# Copie para .env e preencha os valores

# 1. Token do seu bot Telegram
#    Crie em: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=seu_token_aqui

# 2. API key do Google Gemini (GRATUITA)
#    Obtenha em: https://aistudio.google.com/apikey
#    Sem cartão de crédito!
GEMINI_API_KEY=AIzaSy_sua_chave_aqui

# 3. Seu Telegram user ID (segurança — só você usa o bot)
#    Descubra enviando qualquer mensagem para @userinfobot
ALLOWED_USER_ID=seu_id_aqui

# 4. Caminho da pasta do seu vault do Obsidian
OBSIDIAN_VAULT_PATH=/caminho/do/seu/vault



